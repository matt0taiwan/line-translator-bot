# —— Required ——
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# —— Optional ——
# 私訊此 user ID 會走 OpenClaw AI（而非翻譯）；留空 = 停用 admin AI 路徑
OWNER_USER_ID=

# OpenClaw API token；留空 = 停用 admin AI 路徑（會 fallback 到 /help 系列指令）
OPENCLAW_API_TOKEN=

# —— 進階（通常不用動，這裡是預設值） ——
# APP_HOST=0.0.0.0
# APP_PORT=5000
# DEBUG=false
# OPENCLAW_URL=http://host.docker.internal:18789/v1/chat/completions
# OPENCLAW_TIMEOUT=120.0
# OPENCLAW_REPLY_WINDOW=20
# PROFILE_CACHE_TTL=3600
# PROFILE_CACHE_SIZE=512
# TRANSLATOR_WORKERS=4
